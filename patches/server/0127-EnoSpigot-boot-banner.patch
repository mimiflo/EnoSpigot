From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Enofight <team@enofight.com>
Date: Fri, 25 Apr 2026 17:00:00 +0000
Subject: [PATCH] EnoSpigot boot banner

Print a small Enofight ASCII header from Main.main() right before
the "Loading libraries, please wait..." line that Bukkit prints
itself. log4j2 isn't initialised yet at this point, so we write
ANSI sequences directly to stdout — JLine handles the rest once
TerminalConsoleAppender takes over.

Effect: every gameserver / hub container shows the Enofight brand
as the very first thing in its console, instead of starting on a
wall of class loads.


diff --git a/src/main/java/org/bukkit/craftbukkit/Main.java b/src/main/java/org/bukkit/craftbukkit/Main.java
index d8d19207e4db256befa886bc9638759ed7c926dc..0000000000000000000000000000000000000001 100644
--- a/src/main/java/org/bukkit/craftbukkit/Main.java
+++ b/src/main/java/org/bukkit/craftbukkit/Main.java
@@ -231,7 +231,8 @@ public class Main {
                 }
                 // Spigot End
                 */
                 // PandaSpigot end
+                printEnofightBanner(); // EnoSpigot - branded boot banner
                 System.out.println("Loading libraries, please wait...");
                 MinecraftServer.main(options);
             } catch (Throwable t) {
@@ -239,4 +240,28 @@ public class Main {
             t.printStackTrace();
         }
     }
+
+    // EnoSpigot start - branded boot banner printed before Bukkit's "Loading libraries"
+    private static void printEnofightBanner() {
+        String reset  = "[0m";
+        String purple = "[38;5;141m";
+        String gold   = "[38;5;220m";
+        String dim    = "[38;5;245m";
+        String[] banner = {
+                "",
+                purple + "  ███████╗███╗   ██╗ ██████╗ ███████╗██╗ ██████╗ ██╗  ██╗████████╗" + reset,
+                purple + "  ██╔════╝████╗  ██║██╔═══██╗██╔════╝██║██╔════╝ ██║  ██║╚══██╔══╝" + reset,
+                purple + "  █████╗  ██╔██╗ ██║██║   ██║█████╗  ██║██║  ███╗███████║   ██║   " + reset,
+                purple + "  ██╔══╝  ██║╚██╗██║██║   ██║██╔══╝  ██║██║   ██║██╔══██║   ██║   " + reset,
+                purple + "  ███████╗██║ ╚████║╚██████╔╝██║     ██║╚██████╔╝██║  ██║   ██║   " + reset,
+                purple + "  ╚══════╝╚═╝  ╚═══╝ ╚═════╝ ╚═╝     ╚═╝ ╚═════╝ ╚═╝  ╚═╝   ╚═╝   " + reset,
+                dim + "  EnoSpigot " + gold + "1.8.8" + dim + " — fork PandaSpigot/Paper" + reset,
+                "",
+        };
+        for (String line : banner) {
+            System.out.println(line);
+        }
+        System.out.flush();
+    }
+    // EnoSpigot end
 }
