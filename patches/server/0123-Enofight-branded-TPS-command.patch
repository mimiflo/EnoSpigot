+    private static TextComponent buildTimingsLine()
+    {
+        TextComponent line = component( BAR + label( "Timings" ) + ARROW );
+
+        boolean enabled = isTimingsEnabled();
+        TextComponent toggle;
+        if ( enabled )
+        {
+            toggle = clickable( ChatColor.RED + "[\u25A0 D\u00e9sactiver]", "/timings off",
+                    ChatColor.GRAY + "Cliquer pour " + ChatColor.RED + "d\u00e9sactiver " + ChatColor.GRAY + "le profilage" );
+        }
+        else
+        {
+            toggle = clickable( ChatColor.GREEN + "[\u25B6 Activer]", "/timings on",
+                    ChatColor.GRAY + "Cliquer pour " + ChatColor.GREEN + "activer " + ChatColor.GRAY + "le profilage" );
+        }
+        line.addExtra( toggle );
+        line.addExtra( new TextComponent( "  " ) );
+        line.addExtra( clickable( ChatColor.YELLOW + "[\u2191 Exporter]", "/timings paste",
+                ChatColor.GRAY + "Publier le rapport en ligne" ) );
+        line.addExtra( new TextComponent( "  " ) );
+        line.addExtra( clickable( ChatColor.GRAY + "[\u21BA Reset]", "/timings reset",
+                ChatColor.GRAY + "Vider les compteurs" ) );
+
+        return line;
+    }
+
+    private static String plainTimingsLine()
+    {
+        boolean enabled = isTimingsEnabled();
+        return ( enabled ? ChatColor.GREEN + "actifs" : ChatColor.RED + "inactifs" )
+                + ChatColor.DARK_GRAY + "  (utiliser " + ChatColor.GRAY + "/timings " + ( enabled ? "off" : "on" ) + ChatColor.DARK_GRAY + ")";
+    }
+
+    private static boolean isTimingsEnabled()
+    {
+        try { return co.aikar.timings.Timings.isTimingsEnabled(); }
+        catch ( Throwable t ) { return false; }
+    }
+
+    private static String label(String s)
+    {
+        StringBuilder sb = new StringBuilder( ChatColor.GRAY.toString() ).append( s );
+        int padLen = LABEL_PAD.length() - s.length();
+        if ( padLen > 0 ) sb.append( LABEL_PAD, 0, padLen );
+        return sb.toString();
+    }
+
+    private static TextComponent component(String s)
+    {
+        TextComponent root = new TextComponent( "" );
+        for ( BaseComponent c : TextComponent.fromLegacyText( s ) ) root.addExtra( c );
+        return root;
+    }
+
+    private static HoverEvent hover(String text)
+    {
+        return new HoverEvent( HoverEvent.Action.SHOW_TEXT, TextComponent.fromLegacyText( text ) );
+    }
+
+    private static TextComponent clickable(String label, String command, String hoverText)
+    {
+        TextComponent c = component( label );
+        c.setClickEvent( new ClickEvent( ClickEvent.Action.RUN_COMMAND, command ) );
+        c.setHoverEvent( hover( hoverText ) );
+        return c;
+    }
+
+    private static String buildGraph(double[] tps)
+    {
+        ChatColor[] colors = { ChatColor.DARK_GREEN, ChatColor.GREEN, ChatColor.YELLOW, ChatColor.GOLD, ChatColor.RED };
+        int[] levels = { 20, 15, 10, 5, 1 };
+        StringBuilder sb = new StringBuilder( ChatColor.GRAY + "Graphique TPS" + ChatColor.DARK_GRAY + "  (1m, 5m, 15m)\n\n" );
+        for ( int row = 0; row < levels.length; row++ )
+        {
+            sb.append( colors[row] ).append( String.format( "%2d", levels[row] ) )
+              .append( ChatColor.DARK_GRAY ).append( " \u2502 " );
+            for ( int i = 0; i < tps.length; i++ )
+            {
+                double t = Math.min( tps[i], 20.0 );
+                if ( t >= levels[row] ) sb.append( colors[row] ).append( "\u2588\u2588 " );
+                else sb.append( ChatColor.DARK_GRAY ).append( "\u2591\u2591 " );
+            }
+            sb.append( "\n" );
+        }
+        sb.append( ChatColor.DARK_GRAY ).append( "    1m  5m  15m" );
+        return sb.toString();
+    }
+
+    private static String buildMemoryDetail()
+    {
+        Runtime rt = Runtime.getRuntime();
+        long usedMb = ( rt.totalMemory() - rt.freeMemory() ) / 1048576L;
+        long totalMb = rt.totalMemory() / 1048576L;
+        long maxMb = rt.maxMemory() / 1048576L;
+        long freeMb = maxMb - usedMb;
+        long pct = maxMb > 0 ? ( usedMb * 100 / maxMb ) : 0;
+        ChatColor c = colorFor( usedMb, maxMb );
+        return ChatColor.GRAY + "M\u00e9moire JVM\n\n"
+             + ChatColor.GRAY + "Utilis\u00e9e " + ARROW + c + usedMb + ChatColor.DARK_GRAY + " MB " + ChatColor.GRAY + "(" + c + pct + "%" + ChatColor.GRAY + ")\n"
+             + ChatColor.GRAY + "Libre     " + ARROW + ChatColor.GREEN + freeMb + ChatColor.DARK_GRAY + " MB\n"
+             + ChatColor.GRAY + "Allou\u00e9e  " + ARROW + ChatColor.YELLOW + totalMb + ChatColor.DARK_GRAY + " MB\n"
+             + ChatColor.GRAY + "Maximum   " + ARROW + ChatColor.GRAY + maxMb + ChatColor.DARK_GRAY + " MB";
+    }
+
+    private static ChatColor colorFor(long used, long max)
+    {
+        if ( max <= 0 ) return ChatColor.GRAY;
+        return used < max * 7 / 10 ? ChatColor.GREEN : used < max * 9 / 10 ? ChatColor.YELLOW : ChatColor.RED;
+    }
+
+    private static String formatUptime()
+    {
+        long ms = ManagementFactory.getRuntimeMXBean().getUptime();
+        long days = TimeUnit.MILLISECONDS.toDays( ms );
+        long hours = TimeUnit.MILLISECONDS.toHours( ms ) % 24;
+        long minutes = TimeUnit.MILLISECONDS.toMinutes( ms ) % 60;
+        long seconds = TimeUnit.MILLISECONDS.toSeconds( ms ) % 60;
+        StringBuilder sb = new StringBuilder();
+        if ( days > 0 ) sb.append( days ).append( "j " );
+        if ( hours > 0 ) sb.append( hours ).append( "h " );
+        if ( minutes > 0 || days == 0 ) sb.append( minutes ).append( "m " );
+        if ( days == 0 ) sb.append( seconds ).append( "s" );
+        return sb.toString().trim();
+    }
+    // EnoSpigot end
+
     private static String format(double tps) // PaperSpigot - made static
     {
         return ( ( tps > 18.0 ) ? ChatColor.GREEN : ( tps > 16.0 ) ? ChatColor.YELLOW : ChatColor.RED ).toString()
-- 
