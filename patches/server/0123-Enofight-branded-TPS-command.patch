+    // EnoSpigot start - helpers
+    private static TextComponent clickable(String label, String command, String hover)
+    {
+        TextComponent c = new TextComponent( label );
+        c.setClickEvent( new ClickEvent( ClickEvent.Action.RUN_COMMAND, command ) );
+        c.setHoverEvent( new HoverEvent( HoverEvent.Action.SHOW_TEXT, new ComponentBuilder( ChatColor.GRAY + hover ).create() ) );
+        return c;
+    }
+
+    private static String buildGraph(double[] tps)
+    {
+        ChatColor[] colors = { ChatColor.DARK_GREEN, ChatColor.GREEN, ChatColor.YELLOW, ChatColor.GOLD, ChatColor.RED };
+        double[] levels = { 20.0, 15.0, 10.0, 5.0, 0.1 };
+        StringBuilder sb = new StringBuilder();
+        for ( int row = 0; row < levels.length; row++ )
+        {
+            sb.append( colors[row] ).append( (int) levels[row] ).append( ChatColor.DARK_GRAY ).append( " \u2502 " );
+            for ( int i = 0; i < tps.length; i++ )
+            {
+                double t = Math.min( tps[i], 20.0 );
+                if ( t >= levels[row] ) sb.append( colors[row] ).append( "\u2588" );
+                else sb.append( ChatColor.DARK_GRAY ).append( "\u2591" );
+            }
+            if ( row < levels.length - 1 ) sb.append( "\n" );
+        }
+        return sb.toString();
+    }
+
+    private static String formatUptime()
+    {
+        long ms = ManagementFactory.getRuntimeMXBean().getUptime();
+        long days = TimeUnit.MILLISECONDS.toDays( ms );
+        long hours = TimeUnit.MILLISECONDS.toHours( ms ) % 24;
+        long minutes = TimeUnit.MILLISECONDS.toMinutes( ms ) % 60;
+        long seconds = TimeUnit.MILLISECONDS.toSeconds( ms ) % 60;
+        StringBuilder sb = new StringBuilder();
+        if ( days > 0 ) sb.append( days ).append( "j " );
+        if ( hours > 0 ) sb.append( hours ).append( "h " );
+        if ( minutes > 0 ) sb.append( minutes ).append( "m " );
+        sb.append( seconds ).append( "s" );
+        return sb.toString();
+    }
+
+    private static String summarizeMemory()
+    {
+        Runtime rt = Runtime.getRuntime();
+        long usedMb = ( rt.totalMemory() - rt.freeMemory() ) / 1048576L;
+        long maxMb = rt.maxMemory() / 1048576L;
+        ChatColor c = usedMb < maxMb * 7 / 10 ? ChatColor.GREEN : usedMb < maxMb * 9 / 10 ? ChatColor.YELLOW : ChatColor.RED;
+        return c + "" + usedMb + ChatColor.DARK_GRAY + "/" + ChatColor.GRAY + maxMb + ChatColor.DARK_GRAY + " MB";
+    }
+
+    private static String summarizeServer()
+    {
+        return ChatColor.YELLOW + "" + Bukkit.getOnlinePlayers().size() + ChatColor.DARK_GRAY + "/" + ChatColor.GRAY + Bukkit.getMaxPlayers() + ChatColor.DARK_GRAY + " joueurs";
+    }
+
+    private static String buildMemoryInfo()
+    {
+        Runtime rt = Runtime.getRuntime();
+        long usedMb = ( rt.totalMemory() - rt.freeMemory() ) / 1048576L;
+        long totalMb = rt.totalMemory() / 1048576L;
+        long maxMb = rt.maxMemory() / 1048576L;
+        long freeMb = maxMb - usedMb;
+        ChatColor c = usedMb < maxMb * 7 / 10 ? ChatColor.GREEN : usedMb < maxMb * 9 / 10 ? ChatColor.YELLOW : ChatColor.RED;
+        return ChatColor.GRAY + "Utilis\u00e9e " + ChatColor.DARK_GRAY + "\u25b8 " + c + usedMb + ChatColor.DARK_GRAY + " / " + ChatColor.GRAY + maxMb + ChatColor.DARK_GRAY + " MB\n"
+             + ChatColor.GRAY + "Libre    " + ChatColor.DARK_GRAY + "\u25b8 " + ChatColor.GREEN + freeMb + ChatColor.DARK_GRAY + " MB\n"
+             + ChatColor.GRAY + "Allou\u00e9e " + ChatColor.DARK_GRAY + "\u25b8 " + ChatColor.YELLOW + totalMb + ChatColor.DARK_GRAY + " MB";
+    }
+
+    private static String buildServerInfo()
+    {
+        return ChatColor.GRAY + "Joueurs " + ChatColor.DARK_GRAY + "\u25b8 " + ChatColor.YELLOW + Bukkit.getOnlinePlayers().size() + ChatColor.DARK_GRAY + " / " + ChatColor.GRAY + Bukkit.getMaxPlayers() + "\n"
+             + ChatColor.GRAY + "Mondes  " + ChatColor.DARK_GRAY + "\u25b8 " + ChatColor.YELLOW + Bukkit.getWorlds().size() + "\n"
+             + ChatColor.GRAY + "Version " + ChatColor.DARK_GRAY + "\u25b8 " + ChatColor.YELLOW + Bukkit.getVersion() + "\n"
+             + ChatColor.GRAY + "Bukkit  " + ChatColor.DARK_GRAY + "\u25b8 " + ChatColor.YELLOW + Bukkit.getBukkitVersion();
+    }
+    // EnoSpigot end
+
     private static String format(double tps) // PaperSpigot - made static
     {
         return ( ( tps > 18.0 ) ? ChatColor.GREEN : ( tps > 16.0 ) ? ChatColor.YELLOW : ChatColor.RED ).toString()
-- 
