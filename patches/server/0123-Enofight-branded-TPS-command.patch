+    private static final String ARROW = ChatColor.DARK_GRAY + " \u00bb ";
+    private static final String LABEL_PAD = "          "; // 10 chars
+
     @Override
     public boolean execute(CommandSender sender, String currentAlias, String[] args)
     {
@@ -23,18 +41,196 @@ public class TicksPerSecondCommand extends Command
             return true;
         }
 
