+
+// EnoSpigot start - rich /tps command
+import net.md_5.bungee.api.chat.BaseComponent;
+import net.md_5.bungee.api.chat.ClickEvent;
+import net.md_5.bungee.api.chat.HoverEvent;
+import net.md_5.bungee.api.chat.TextComponent;
+import java.lang.management.ManagementFactory;
+import java.util.concurrent.TimeUnit;
+// EnoSpigot end
 
 public class TicksPerSecondCommand extends Command
 {
@@ -13,8 +24,15 @@ public class TicksPerSecondCommand extends Command
         this.description = "Gets the current ticks per second for the server";
         this.usageMessage = "/tps";
         this.setPermission( "bukkit.command.tps" );
+        this.setAliases( java.util.Arrays.asList( "lag" ) ); // EnoSpigot - /lag alias
     }
 
+    // EnoSpigot start - branded /tps with toggleable timings, hover detail, clean layout
+    private static final String BAR = ChatColor.DARK_GRAY + "\u2503 ";
