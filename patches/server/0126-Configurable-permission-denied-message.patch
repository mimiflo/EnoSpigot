From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: EnoFight <claude@enofight.fr>
Date: Fri, 25 Apr 2026 13:30:00 +0000
Subject: [PATCH] Configurable permission-denied message

Adds PandaSpigotConfig.permissionDeniedMessage so the text shown when
a player runs a command without the required permission can be edited
in enospigot.yml without rebuilding. The value is pushed into
org.bukkit.command.CommandMessages.permissionDenied at config-load
time, which is what the default Bukkit testPermission() path renders.

Plugins can still override the value at runtime by writing directly to
CommandMessages.permissionDenied (the config wiring just sets a
sensible startup default).


diff --git a/src/main/java/com/hpfxd/pandaspigot/config/PandaSpigotConfig.java b/src/main/java/com/hpfxd/pandaspigot/config/PandaSpigotConfig.java
index 0000000000000000000000000000000000000001..0000000000000000000000000000000000000001 100644
--- a/src/main/java/com/hpfxd/pandaspigot/config/PandaSpigotConfig.java
+++ b/src/main/java/com/hpfxd/pandaspigot/config/PandaSpigotConfig.java
@@ -33,6 +33,9 @@ public class PandaSpigotConfig {
         try {
             CommentedConfigurationNode root = loader.load();
             config = root.get(PandaSpigotConfig.class);
+            // EnoSpigot - apply configured permission-denied message to the API holder
+            org.bukkit.command.CommandMessages.permissionDenied =
+                org.bukkit.ChatColor.translateAlternateColorCodes('&', config.permissionDeniedMessage);
 
             // worlds
             CommentedConfigurationNode worldsNode = root.node("worlds")
@@ -134,4 +137,11 @@ public class PandaSpigotConfig {
         "Set to 0 for automatic detection (half of available CPU cores, minimum 2).\n" +
         "Only used when asyncEntityTracker is enabled.")
     public int asyncEntityTrackerThreads = 0;
+
+    @Comment("Message shown when a player tries to run a command they don't have\n" +
+        "permission for. Plugins may also override the resolved value at runtime via\n" +
+        "org.bukkit.command.CommandMessages.permissionDenied.\n" +
+        "Uses ChatColor codes (&). Default mirrors spigot.yml's unknown-command so\n" +
+        "command existence stays opaque to non-staff players.")
+    public String permissionDeniedMessage = "&cCommande inconnue. Utilise /help pour la liste.";
 }
