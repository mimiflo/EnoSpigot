From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Enofight <team@enofight.com>
Date: Fri, 25 Apr 2026 18:00:00 +0000
Subject: [PATCH] Branded version banner

Replaces the old vertical-bar version banner with a clean
two-line box matching the gameserver plugin's "Server READY"
output. Includes the Enofight ASCII art on top so the brand
appears directly above the version info.


diff --git a/src/main/java/org/bukkit/Bukkit.java b/src/main/java/org/bukkit/Bukkit.java
index 2ae8b301052020afc17c15435d8022c55cce9675..0000000000000000000000000000000000000001 100644
--- a/src/main/java/org/bukkit/Bukkit.java
+++ b/src/main/java/org/bukkit/Bukkit.java
@@ -90,7 +90,25 @@ public final class Bukkit {
         if ("master".equals(gitBranch) || "main".equals(gitBranch)) {
             branchMsg = "";  // Don't show branch on main/master
         }
-        return "\n\u00A75\u00A7l  Enofight \u00A78/ \u00A77\u00A7oInformations\n \n\u00A78\u2503 \u00A77Version    \u00A78 \u00bb \u00A7e" + getVersion() + "\n\u00A78\u2503 \u00A77API        \u00A78 \u00bb \u00A7e" + getBukkitVersion() + "\n\u00A78\u2503 \u00A77Git        \u00A78 \u00bb \u00A7e" + gitCommit + branchMsg;
